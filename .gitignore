# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# 每日抓取的暫存資料（由 CI 產生，不進 repo）
/data/*
# 例外：概念股分類是版控資料（P2-1），不是 CI 產物（/data/ 需寫成 /data/* 例外才會生效）
!/data/concept-sectors.json

# typescript
*.tsbuildinfo
next-env.d.ts

# iCloud workaround（.nosync 不進 iCloud 也不進 git）
.git.nosync/
node_modules.nosync/
